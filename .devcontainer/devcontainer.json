{
    "name": "My-Linux-Server",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/node:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-ceintl.vscode-language-pack-bn"
            ]
        }
    },
    "postCreateCommand": "sudo apt update && sudo apt install -y htop curl wget neofetch"
}
